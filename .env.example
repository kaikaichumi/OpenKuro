# Kuro - Personal AI Assistant
# Copy this file to .env and fill in your API keys

# === LLM Providers ===
# At least one provider is required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here  # Legacy alias (optional)

# === OpenAI OAuth Subscription (optional, for ChatGPT Plus/Pro traffic in Web UI) ===
# Uses OpenAI Codex public OAuth client by default (no client secret required).
# Optional overrides:
# OPENAI_CODEX_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# OPENAI_CODEX_OAUTH_SCOPE=openid profile email offline_access
# OPENAI_CODEX_OAUTH_REDIRECT_URI=http://localhost:7860/auth/callback
# OPENAI_CODEX_OAUTH_REDIRECT_PATH=/auth/callback
# OPENAI_CODEX_OAUTH_FORCE_LOCALHOST=1
# OPENAI_CODEX_OAUTH_LOCAL_BRIDGE=1
# OPENAI_CODEX_OAUTH_BRIDGE_HOST=127.0.0.1
# OPENAI_CODEX_OAUTH_BRIDGE_PORT=1455
# OPENAI_CODEX_OAUTH_BRIDGE_PATH=/auth/callback
# OPENAI_CODEX_OAUTH_AUTH_URL=https://auth.openai.com/oauth/authorize
# OPENAI_CODEX_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
# OPENAI_CODEX_OAUTH_ORIGINATOR=codex_cli_rs
# OPENAI_CODEX_OAUTH_MODELS=gpt-5.4,gpt-5.4-pro,gpt-5.3-codex,gpt-5.3-chat-latest,gpt-5.2-pro,gpt-5.2-codex,gpt-5.2-chat-latest,gpt-5.2,gpt-5-pro,gpt-5.1-codex-max,gpt-5.1-codex,gpt-5.1-codex-mini,gpt-5.1-chat-latest,gpt-5.1,gpt-5-codex,gpt-5-chat-latest,gpt-5,codex-mini-latest
# OPENAI_CODEX_INSTRUCTIONS=You are Codex, a software engineering assistant running in a local user workspace.
# OPENAI_OAUTH_COOKIE_SECURE=0

# === Local Models (Ollama) ===
# Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# === Messaging Adapters ===
# Telegram (optional)
# KURO_TELEGRAM_TOKEN=your_telegram_bot_token_here

# Discord (optional)
# KURO_DISCORD_TOKEN=your_discord_bot_token_here

# Slack (optional, Socket Mode)
# KURO_SLACK_BOT_TOKEN=xoxb-...
# KURO_SLACK_APP_TOKEN=xapp-...

# LINE (optional)
# KURO_LINE_ACCESS_TOKEN=your_line_token_here
# KURO_LINE_CHANNEL_SECRET=your_line_secret_here

# Email (optional)
# KURO_EMAIL_ADDRESS=you@example.com
# KURO_EMAIL_PASSWORD=your_app_password_here

# === Google Calendar (optional) ===
# GOOGLE_CALENDAR_CREDENTIALS_PATH=~/.kuro/google_credentials.json
